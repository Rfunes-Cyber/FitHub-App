<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.text.Text?>
<?import javafx.scene.control.*?>
<?import javafx.scene.image.*?>
<?import javafx.scene.layout.AnchorPane?>

<AnchorPane prefHeight="960.0" prefWidth="540.0"
 xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
 fx:controller="edu.utsa.cs3443.fithubapp.controller.PasswordResetController">
    <children>
        <ImageView fitHeight="960" fitWidth="540" preserveRatio="false">
            <image><Image url="@../images/reset-background.png"/></image>
        </ImageView>

        <!-- FitHub Logo -->

        <HBox
                layoutX="40"
                layoutY="28"
                spacing="0"
                alignment="CENTER_LEFT">

            <Text
                    text="Fit"
                    styleClass="fit-logo"/>

            <Text
                    text="Hub"
                    styleClass="hub-logo"/>

        </HBox>

        <TextField fx:id="usernameField"
                   layoutX="105" layoutY="174"
                   prefHeight="45" prefWidth="337"
                   promptText="User Name"
                   styleClass="auth-field"/>

        <PasswordField fx:id="newPasswordField"
                       layoutX="105" layoutY="262"
                       prefHeight="45" prefWidth="337"
                       promptText="New Password"
                       styleClass="auth-field"/>

        <PasswordField fx:id="verifyPasswordField"
                       layoutX="105" layoutY="350"
                       prefHeight="45" prefWidth="337"
                       promptText="Verify Password"
                       styleClass="auth-field"/>

        <Button layoutX="108" layoutY="447"
                prefHeight="46" prefWidth="314"
                text="Reset Password"
                onAction="#handleResetPassword"
                styleClass="primary-button"/>

        <Button layoutX="225" layoutY="520"
                text="Cancel"
                onAction="#returnToLogin"
                styleClass="link-button italic-link"/>

        <Label fx:id="messageLabel"
               alignment="CENTER"
               layoutX="70" layoutY="580"
               prefWidth="400"
               wrapText="true"
               styleClass="message-label"/>
    </children>
</AnchorPane>
